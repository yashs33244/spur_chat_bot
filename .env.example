# ===========================================
# LLM Provider Configuration
# ===========================================
# Choose your provider: openai | openai_compatible | anthropic | openrouter | gemini | deepseek | ollama
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash-lite
LLM_API_KEY=your-api-key-here
# LLM_API_BASE=  # required for openai_compatible and ollama

# --- OpenAI ---
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=sk-...

# --- Anthropic ---
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-3-haiku-20240307
# LLM_API_KEY=sk-ant-...

# --- OpenRouter (200+ models) ---
# LLM_PROVIDER=openrouter
# LLM_MODEL=meta-llama/llama-3.1-8b-instruct:free
# LLM_API_KEY=sk-or-v1-...

# --- DeepSeek ---
# LLM_PROVIDER=deepseek
# LLM_MODEL=deepseek-chat
# LLM_API_KEY=sk-...

# --- Ollama (local) ---
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.2
# LLM_API_BASE=http://localhost:11434

# --- Any OpenAI-compatible API ---
# LLM_PROVIDER=openai_compatible
# LLM_MODEL=your-model-name
# LLM_API_KEY=your-key
# LLM_API_BASE=http://localhost:8080/v1

# ===========================================
# Database
# ===========================================
DATABASE_URL=postgresql://user:password@localhost:5432/spurdb

# ===========================================
# App Config
# ===========================================
MAX_CONTEXT_MESSAGES=20
MAX_MESSAGE_LENGTH=2000
RATE_LIMIT_RPM=20

# ===========================================
# Web Push / VAPID (server-side push notifications)
# Generate new keys: npx web-push generate-vapid-keys
# ===========================================
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key-here
VAPID_PRIVATE_KEY=your-vapid-private-key-here
VAPID_EMAIL=support@spurnow.com
# CRON_SECRET=your-random-secret  # set this in Vercel to protect the cron endpoint
